# Chave da API Anthropic (Claude)
# Local: fica em C:/Users/Ruds/.epiuse-optimizer/.env (fora do Google Drive)
# Railway: adicionar como variável de ambiente no painel do projeto
ANTHROPIC_API_KEY=sua_chave_aqui

# Porta local (Railway define PORT automaticamente — não precisa setar lá)
PORT=3000

# ── Email (LP "Seja um Voice") ─────────────────────────────────────────
# Resend.com — 3000 emails/mês grátis, conta criada em 2min
# Setup:
#   1. resend.com -> Sign up
#   2. Dashboard -> API Keys -> Create -> copia a key (formato re_...)
#   3. Local: cola aqui (em C:/Users/Ruds/.epiuse-optimizer/.env)
#   4. Railway: Project -> Variables -> RESEND_API_KEY
# Sem a key: sistema funciona normal, só não dispara email (cai pra JSONL+console)
RESEND_API_KEY=

# Para onde envia notificação de nova inscrição na LP
NOTIFY_EMAIL=ruda.costa@epiuse.com.br

# Webhook Power Automate do fluxo de brindes (URL do trigger com assinatura SAS).
# Usado pelo proxy POST /api/brindes/notify. A URL antiga vazou no repo público —
# recriar o trigger no Power Automate e colar a URL nova AQUI (Railway env var).
POWERAUTOMATE_BRINDES_WEBHOOK=

# Remetente. Default usa o domain resend.dev (sem setup).
# Pra usar @epiuse.com.br, verificar o domain no Resend primeiro.
FROM_EMAIL=voices@resend.dev

# ── Editor Token (PUT/POST sensíveis: voices, cases, calendar) ─────────
# String aleatória FORTE (gere com: openssl rand -hex 32).
# Obrigatório para: scripts de sync (scripts/sync/*.js, scripts/lifecycle/*.ps1),
# geração de PPTX em produção e qualquer automação/IA que chame a API do Railway.
# Todos os scripts falham com erro claro se esta var não estiver setada.
# NUNCA commitar o valor — compartilhar entre devs só por canal seguro (ver SECURITY.md).
EDITOR_TOKEN=

# ── RD Station — calendário editorial (sprint 0.4.0) ────────────────────
# Critério/registro: https://appstore.rdstation.com/en/publisher/<id>/api_keys
# Usado pelo POST /api/inbound/sync-rd pra puxar email marketing campaigns
RD_API_KEY=
RD_PUBLISHER_ID=

# ── SSO Microsoft + Roles por perfil ───────────────────────────────────
# Quando IT EPI-USE registrar o app no Azure AD, preencher abaixo.
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
AZURE_CLIENT_SECRET=
AZURE_REDIRECT_URI=https://epiuse-voices-optimizer.up.railway.app/auth/callback
SESSION_SECRET=
# Domínios autorizados a logar (separados por vírgula). Default: epiuse.com.br
SSO_ALLOWED_DOMAINS=epiuse.com.br,epiuselabs.com,groupelephant.com
# Exige login Microsoft em TODAS as páginas. Em produção o comportamento é
# FAIL-CLOSED: sem as credenciais AZURE_* configuradas, o acesso é BLOQUEADO
# (503), nunca aberto. SSO_ENFORCE=false é escape hatch emergencial que
# desliga a autenticação inteira — só usar sabendo o motivo, e reverter logo.
SSO_ENFORCE=true
