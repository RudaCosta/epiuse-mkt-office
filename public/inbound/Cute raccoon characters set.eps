   <dc:description>
    <rdf:Alt>
     <rdf:li xml:lang="x-default">Cute raccoon characters set. Vector illustrations of small wild forest animals. Cartoon funny poses of sleeping, playing, waving adorable raccoon isolated on white. Woodland, nature, mascot concept</rdf:li>
    </rdf:Alt>
